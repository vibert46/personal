<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Site" }}</title>
  <meta name="description" content="{{ site.description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="frame">
    <nav class="nav">
      <ul class="nav-list">
        {% for item in nav %}
        <li>
          <a href="{{ item.url }}" class="{% if page.url == item.url %}is-active{% endif %}">{{ item.label }}</a>
        </li>
        {% endfor %}
      </ul>
    </nav>
    <main class="content">
      {{ content | safe }}
    </main>
  </div>
</body>
</html>
